# =============================================
# Truedy Voice AI - Server Configuration
# =============================================

# Sua API Key da Truedy (Dashboard → Settings → API Keys)
TRUEDY_API_KEY=YOUR_TRUEDY_API_KEY_HERE

# Porta do servidor (padrão: 3000)
PORT=3000

# Domínios permitidos no CORS (separar por vírgula)
# Ex: https://seusite.com,https://www.seusite.com
# Use * para permitir todos (somente em dev)
ALLOWED_ORIGINS=*
